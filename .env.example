# ====================================
# Jogy Flutter App - 环境配置模板
# ====================================
# 使用方法：
#   1. 复制此文件: cp .env.example .env
#   2. 在 .env 中填入你的真实值
#   3. .env 不会被提交到 Git（已在 .gitignore 中）

# ---- 后端 API 地址 ----
# 本地开发: http://localhost:8000/api/v1
# Android 模拟器: http://10.0.2.2:8000/api/v1
# 生产环境: https://your-domain.com/api/v1
API_BASE_URL=http://localhost:8000/api/v1

# ---- Mapbox ----
# 在 https://account.mapbox.com/ 获取你的 access token
MAPBOX_API_KEY=your_mapbox_public_token_here
